{
  "name": "postgres-parquet-export",
  "version": "1.0.0",
  "description": "PostgreSQL to Parquet export using AWS Lambda",
  "type": "module",
  "main": "dist/handler/lambdaHandler.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "npm run build && node dist/test/localtest.js",
    "start": "node dist/handler/lambdaHandler.js",
    "format": "prettier --write .",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "parquetjs-lite": "^0.8.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/aws-sdk": "^2.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
