generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model well_data {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  date                 DateTime  @db.Timestamp(6)
  asset_id             String
  facility_id          String

  // ✅ TRUE PRODUCTION
  true_oil             Float?
  true_water           Float?
  true_gas             Float?

  // ✅ TEST DATA
  test_oil             Float?
  test_water           Float?
  test_gas             Float?

  // ✅ KPIs
  avg_tubing_pressure  Float?
  avg_casing_pressure  Float?
  avg_motor_amps       Float?
  gross_stroke_len     Float?
  net_stroke_len       Float?
  spm                  Float?
  pump_fillage_pct     Float?
  freq_hz              Float?
  pump_intake_pressure Float?
  motor_temp_f         Float?
  injection_rate_mcf   Float?

  // ✅ STATUS
  status               String?
  notes                String?

  // ✅ INDEXES (VERY IMPORTANT)
  @@index([asset_id, date])
  @@index([facility_id, date])
}

model production_history {
  id            BigInt    @id @default(autoincrement())
  asset_id      String?
  date          DateTime? @db.Date
  allocated_oil Float?
  motor_temp_f  Float?
  status        String?
  notes         String?

  @@index([asset_id, date], map: "idx_asset_date")
}

model invoices {
  id                  BigInt    @id @default(autoincrement())
  invoice_id          String?
  invoice_date        DateTime? @db.Date
  category            String?
  gl_code             String?
  service_description String?
  vendor              String?
  asset_id            String?
  total_usd           Float?

  @@index([asset_id, invoice_date], map: "idx_invoice_asset_date")
}
