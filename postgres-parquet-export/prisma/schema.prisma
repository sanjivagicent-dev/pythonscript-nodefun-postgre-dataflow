generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model well_data {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date                 DateTime? @db.Timestamp(6)
  asset_id             String?
  facility_id          String?
  allocated_oil        Float?
  avg_tubing_pressure  Float?
  avg_casing_pressure  Float?
  avg_motor_amps       Float?
  gross_stroke_len     Float?
  net_stroke_len       Float?
  spm                  Float?
  pump_fillage_pct     Float?
  freq_hz              Float?
  pump_intake_pressure Float?
  motor_temp_f         Float?
  injection_rate_mcf   Float?
  status               String?
  notes                String?
}

model production_history {
  id            BigInt    @id @default(autoincrement())
  asset_id      String?
  date          DateTime? @db.Date
  allocated_oil Float?
  motor_temp_f  Float?
  status        String?
  notes         String?

  @@index([asset_id, date], map: "idx_asset_date")
}

model invoices {
  id                  BigInt    @id @default(autoincrement())
  invoice_id          String?
  invoice_date        DateTime? @db.Date
  category            String?
  gl_code             String?
  service_description String?
  vendor              String?
  asset_id            String?
  total_usd           Float?

  @@index([asset_id, invoice_date], map: "idx_invoice_asset_date")
}
